{
  "name": "yobi",
  "version": "0.1.0",
  "description": "Desktop AI companion powered by Telegram",
  "license": "AGPL-3.0-only",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "prebuild": "npm run prebuild:openclaw && npm run prebuild:live2d-core",
    "prebuild:openclaw": "node build/prebuild-openclaw-runtime.mjs",
    "prebuild:live2d-core": "node build/prebuild-live2d-core.mjs",
    "build": "electron-vite build",
    "dist:mac": "npm run build && npx electron-builder --mac dmg --publish never",
    "dist:win": "npm run build && npx electron-builder --win nsis --publish never",
    "preview": "electron-vite preview",
    "test": "rm -rf out/src/main out/tsconfig.node.tsbuildinfo && tsc -p tsconfig.node.json && node --experimental-specifier-resolution=node --loader ./scripts/alias-loader.mjs --test out/src/main/tests/*.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.4",
    "@ai-sdk/openai": "^2.0.10",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "ai": "^5.0.90",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "edge-tts-universal": "^1.4.0",
    "grammy": "^1.35.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.542.0",
    "node-llama-cpp": "^3.17.1",
    "node-screenshots": "^0.2.1",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "uiohook-napi": "^1.5.4",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "electron": "^37.4.0",
    "electron-vite": "^4.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  },
  "build": {
    "appId": "com.yobi.app",
    "productName": "Yobi",
    "artifactName": "Yobi-${version}.${ext}",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!resources/models{,/**}",
      "!resources/openclaw-runtime{,/**}",
      "!**/.DS_Store"
    ],
    "extraResources": [
      {
        "from": "resources/openclaw-runtime",
        "to": "openclaw-runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "build/icon.png",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Yobi 需要麦克风权限来进行语音输入与实时对话。"
      },
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
