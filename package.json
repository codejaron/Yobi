{
  "name": "yobi",
  "version": "0.1.0",
  "description": "Desktop AI companion powered by Telegram",
  "license": "AGPL-3.0-only",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "prebuild": "npm run prebuild:live2d-core && npm run prebuild:sensevoice-assets && npm run prebuild:mac-screen-capture-helper && npm run prebuild:native-audio-helper",
    "prebuild:mac-screen-capture-helper": "node build/build-mac-screen-capture-helper.mjs",
    "prebuild:native-audio-helper": "node build/build-native-audio-helper.mjs",
    "prebuild:live2d-core": "node build/prebuild-live2d-core.mjs",
    "prebuild:sensevoice-assets": "node build/prebuild-sensevoice-assets.mjs",
    "build:sensevoice-backend": "node build/build-sensevoice-backend.mjs",
    "build": "electron-vite build",
    "dist:mac": "npm run build && electron-builder --mac dmg --publish never",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "preview": "electron-vite preview",
    "test": "node ./scripts/clean-test-output.mjs && tsc -p tsconfig.node.json && node ./scripts/run-node-tests.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "^1.0.13",
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/deepseek": "^2.0.26",
    "@ai-sdk/moonshotai": "^2.0.12",
    "@ai-sdk/openai": "^3.0.48",
    "@pixi/sound": "^5.2.3",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@msgpack/msgpack": "^3.1.3",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@types/qrcode": "^1.5.6",
    "ai": "^6.0.137",
    "avr-vad": "^1.0.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "d3": "^7.9.0",
    "edge-tts-universal": "^1.4.0",
    "grammy": "^1.35.1",
    "jieba-wasm": "^2.4.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.542.0",
    "node-llama-cpp": "^3.17.1",
    "node-screenshots": "^0.2.1",
    "pixi-live2d-display-advanced": "^1.1.0",
    "pixi.js": "^7.4.3",
    "playwright": "^1.58.2",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.1",
    "uiohook-napi": "^1.5.4",
    "vercel-minimax-ai-provider": "^0.0.2",
    "zhipu-ai-provider": "^0.2.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "electron": "^37.4.0",
    "electron-builder": "26.8.1",
    "electron-vite": "^4.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  },
  "build": {
    "appId": "com.yobi.app",
    "productName": "Yobi",
    "artifactName": "Yobi-${version}.${ext}",
    "icon": "build/icon.png",
    "electronDist": "node_modules/electron/dist",
    "asarUnpack": [
      "node_modules/@node-llama-cpp/**",
      "node_modules/avr-vad/**/*.onnx",
      "node_modules/onnxruntime-node/**"
    ],
    "extraResources": [
      {
        "from": "resources/sensevoice/bin",
        "to": "sensevoice/bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/mac-screen-capture/bin",
        "to": "mac-screen-capture/bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/native-audio/bin",
        "to": "native-audio/bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!resources/models{,/**}",
      "!**/.DS_Store"
    ],
    "mac": {
      "icon": "build/icon.png",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Yobi 需要麦克风权限来进行语音输入与实时对话。"
      },
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
