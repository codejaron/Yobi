{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "types": ["node", "electron-vite/node"],
    "lib": ["ES2022"],
    "outDir": "out"
  },
  "include": [
    "electron.vite.config.ts",
    "src/shared/**/*.ts",
    "src/main/**/*.d.ts",
    "src/main/**/*.ts",
    "src/renderer/pages/dashboard/token-aggregate.ts",
    "src/preload/**/*.d.ts",
    "src/preload/**/*.ts"
  ]
}
